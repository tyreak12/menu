{
  "name": "sheets-menu",
  "version": "1.0.0",
  "private": true,
  "description": "Eleventy restaurant menu site powered by Google Sheets CSV",
  "type": "module",
  "engines": {
    "node": "22.19.0"
  },
  "scripts": {
    "prebuild": "node scripts/build-menu-data.mjs",
    "validate:data": "node scripts/validate-bad-csv.mjs",
    "dev": "npm run prebuild && eleventy --serve --watch",
    "build": "npm run prebuild && eleventy"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "csv-parse": "^5.6.0"
  }
}
