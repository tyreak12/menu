<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ site.menuHeading }} | {{ site.restaurantName }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ 'assets/css/style.css' | url }}">
  </head>
  <body>
    <main class="container py-5">
      {{ content | safe }}
      {% if site.todayHours %}
        <section class="hours mt-4 mt-md-5">
          <h2 class="h6 mb-2">Today's Hours ({{ site.todayHours.day }})</h2>
          <p class="mb-0 text-secondary">
            {% if site.todayHours.open == "Closed" %}
              Closed
            {% else %}
              {{ site.todayHours.open }} - {{ site.todayHours.close }}
            {% endif %}
          </p>
        </section>
      {% endif %}
    </main>
  </body>
</html>
